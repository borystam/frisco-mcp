# under a screenshots/ tree, where this rule blocks them by default.
screenshots/
playwright-report/
test-results/
*.har

# Personal test fixtures — keep them off the public repo.
test_data/personal/

# Local docker overrides.
docker-compose.override.yml
docker-compose.override.yaml

# OS / editor noise.
.DS_Store
.vscode/
.idea/
*.swp
