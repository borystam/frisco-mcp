# Frisco MCP — example environment file.
#
# Copy to `.env` and fill in your own values. `.env` is gitignored;
# `.env.example` is committed for documentation. NEVER commit a real
# bearer, password, or account email.

# Transport — one of: stdio (default), http
MCP_TRANSPORT=http

# HTTP transport binding. Stay on 127.0.0.1 unless the consumer in
# front of you (Hermes, Ollama, …) is on a different host AND you set a
# strong bearer below — the server refuses to bind a non-loopback
# address without one.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3031

# REQUIRED if MCP_HTTP_HOST is non-loopback. Generate locally:
#   openssl rand -base64 32
# Never commit a real value to a public repo.
MCP_HTTP_BEARER=changeme

# Optional limits.
# MCP_HTTP_BODY_LIMIT_BYTES=1048576
# MCP_HTTP_IDLE_TIMEOUT_MS=30000

# Optional: noVNC viewer password. Not required when noVNC is only
# reached over loopback / private network.
# X11VNC_PASSWORD=changeme

# Optional: Frisco autofill credentials. Server reads them only inside
# the `login` tool and never logs them. Leave unset to use the manual
# browser flow over noVNC.
# FRISCO_USER=you@example.invalid
# FRISCO_PASS=changeme
